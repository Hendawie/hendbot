<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="inertial_macros.xacro" />

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1" />
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1" />
    </material>

    <material name="black">
        <color rgba="0 0 0 1" />
    </material>

    <!-- BASE LINK -->

    <link name="base_link">

    </link>

    <!-- BASE_FOOTPRINT LINK -->

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_link" />
        <child link="base_footprint" />
        <origin xyz="0 0 0" rpy="0 0 0" />
    </joint>

    <link name="base_footprint">
    </link>


    <!-- CHASSIS LINK -->

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link" />
        <child link="chassis" />
        <origin xyz="-0.1 0 0" />
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0.35 0 0.1" />
            <geometry>
                <box size="0.7 0.35 0.2" />
            </geometry>
            <material name="orange" />
        </visual>
        <collision>
            <origin xyz="0.35 0 0.1" />
            <geometry>
                <box size="0.7 0.35 0.2" />
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.7" y="0.35" z="0.2">
            <origin xyz="0.35 0 0.1" rpy="0 0 0" />
        </xacro:inertial_box>
    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- LEFT WHEEL LINK -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel" />
        <origin xyz="0 0.225 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.075">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Orange</material>
    </gazebo>


    <!-- RIGHT WHEEL LINK -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel" />
        <origin xyz="0 -0.225 0" rpy="${pi/2} 0 0" />
        <axis xyz="0 0 -1" />
    </joint>

    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.075">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Orange</material>
    </gazebo>

    <!-- LEFT F WHEEL LINK -->

    <joint name="left__front_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="left_font_wheel" />
        <origin xyz="0.46 0.225 0" rpy="-${pi/2} 0 0" />
        <axis xyz="0 0 1" />
    </joint>

    <link name="left_font_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.075">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_font_wheel">
        <material>Gazebo/Orange</material>
        <mu1 value="0.001" />
        <mu2 value="0.001" />
    </gazebo>

    <!-- RIGHT F WHEEL LINK -->

    <joint name="right__front_wheel_joint" type="fixed">
        <parent link="base_link" />
        <child link="right_font_wheel" />
        <origin xyz="0.46 -0.225 0" rpy="${pi/2} 0 0" />
        <axis xyz="0 0 -1" />
    </joint>
 
    <link name="right_font_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.075" length="0.1" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.1" radius="0.075">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_font_wheel">
        <material>Gazebo/Orange</material>
        <mu1 value="0.001" />
        <mu2 value="0.001" />
    </gazebo>

    <!-- RIGHT FLIBER WHEEL LINK -->

    <joint name="right_flibber_wheel_joint" type="revolute">
        <parent link="right_font_wheel" />
        <child link="right_flibber_wheel" />
        <axis xyz="0 1 0" />
        <limit lower="0" upper="${pi}" effort="100" velocity="100"/>
    </joint>

    <xacro:property name="arm_length" value="0.4" />
    <xacro:property name="arm_H" value="0.1" />
    <xacro:property name="arm_W" value="0.1" />
    <xacro:property name="arm_radius" value="0.15" />

    <link name="right_flibber_wheel">
        <visual>
            <origin xyz="${arm_length/2} 0 0" rpy="0 ${pi} 0" />
            <geometry>
                <box size="${arm_length} ${arm_H} ${arm_W}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${arm_length} ${arm_H} ${arm_W}" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="${arm_length}" radius="${arm_radius}">
            <origin xyz="${arm_length/2} 0 0" rpy="0 ${pi} 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="right_flibber_wheel">
        <material>Gazebo/Black</material>
        <mu1 value="0.001" />
        <mu2 value="0.001" />
    </gazebo>


    <!-- LEFT FLIBBER WHEEL LINK -->

    <joint name="left_flibber_wheel_joint" type="revolute">
        <parent link="left_font_wheel" />
        <child link="left_flibber_wheel" />
        <origin xyz="${arm_length} 0 0" rpy="0 -${pi} 0" />
        <axis xyz="0 -1 0" />
        <limit lower="0" upper="${pi}" effort="100" velocity="100"/>
    </joint>

    <link name="left_flibber_wheel">
        <visual>
            <origin xyz="${arm_length/2} 0 0" rpy="0 ${pi} 0" />
            <geometry>
                 <box size="${arm_length} ${arm_H} ${arm_W}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                 <box size="${arm_length} ${arm_H} ${arm_W}" />
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="${arm_length}" radius="${arm_radius}">
            <origin xyz="0 0 0" rpy="0 0 0" />
        </xacro:inertial_cylinder>
    </link>

    <gazebo reference="left_flibber_wheel">
        <material>Gazebo/Black</material>
        <mu1 value="0.001" />
        <mu2 value="0.001" />
    </gazebo>

    <!-- LEFT TRACK-->

    <!-- <joint name="left_track_joint" type="fixed">
        <parent link="base_link" />
